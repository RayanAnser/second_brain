# Copy to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
ELEVENLABS_API_KEY=...
# Optional: override default Charlotte voice (XB0fDUnXU5powFXDhCwa)
# ELEVENLABS_VOICE_ID=XB0fDUnXU5powFXDhCwa

# Telegram chat ID — must match the companion's TELEGRAM_CHAT_ID.
# Needed so fallback_stage writes to the correct bucket in staging.json.
# Run `id` in Telegram with @userinfobot to get yours.
TELEGRAM_CHAT_ID=your_telegram_chat_id

# URL of the running companion HTTP server (default: http://localhost:8765)
COMPANION_URL=http://localhost:8765

# Path to memory/ dir.
# If running dev from WSL terminal → use the Linux path:
#   MEMORY_DIR=/home/rayan/code/RayanAnser/second_brain/memory
# If running dev from Windows terminal → UNC path, MUST be single-quoted (dotenvy eats \\):
#   MEMORY_DIR='\\wsl.localhost\Ubuntu\home\rayan\code\RayanAnser\second_brain\memory'
MEMORY_DIR=/home/rayan/code/RayanAnser/second_brain/memory
